{
  "info": {
    "_postman_id": "8c42fb21-4f10-4bc8-8a8b-c9a90967ab32",
    "name": "DeskFlow - Support Ticket Triage Board API",
    "description": "API collection for testing and verifying the DeskFlow MERN Support Ticket Triage Board application.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create Ticket (Success)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Unable to access billing history tab\",\n  \"description\": \"Clicking the billing tab throws a white screen on the dashboard.\",\n  \"customerEmail\": \"customer@example.com\",\n  \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tickets",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tickets"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Ticket created with derived fields\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"id\");",
                  "    pm.expect(jsonData).to.have.property(\"status\", \"open\");",
                  "    pm.expect(jsonData).to.have.property(\"ageMinutes\");",
                  "    pm.expect(jsonData).to.have.property(\"slaBreached\");",
                  "    // Store created ID to environment for subsequent calls",
                  "    if (jsonData.id) {",
                  "        pm.globals.set(\"ticket_id\", jsonData.id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Ticket (Validation Failure - Bad Email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Test Ticket\",\n  \"description\": \"Missing description details.\",\n  \"customerEmail\": \"invalid-email-address\",\n  \"priority\": \"urgent\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tickets",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tickets"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 400\", () => pm.response.to.have.status(400));",
                  "pm.test(\"Returns validation errors array\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"errors\");",
                  "    pm.expect(jsonData.errors).to.be.an(\"array\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get All Tickets",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tickets",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tickets"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Returns array of tickets\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an(\"array\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Tickets (Filtered by Priority & Status)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tickets?status=open&priority=high",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tickets"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "open"
                },
                {
                  "key": "priority",
                  "value": "high"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Returns list matching criteria\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an(\"array\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Status (open -> in_progress)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tickets/{{ticket_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tickets",
                "{{ticket_id}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Updates status successfully\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.equal(\"in_progress\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Status - Invalid Transition (in_progress -> closed)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"closed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tickets/{{ticket_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tickets",
                "{{ticket_id}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 400\", () => pm.response.to.have.status(400));",
                  "pm.test(\"Returns descriptive transition error\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"error\");",
                  "    pm.expect(jsonData.error).to.include(\"Invalid transition\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Status (in_progress -> resolved)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tickets/{{ticket_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tickets",
                "{{ticket_id}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Sets resolvedAt dynamically\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.equal(\"resolved\");",
                  "    pm.expect(jsonData.resolvedAt).to.not.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete Ticket",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/tickets/{{ticket_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tickets",
                "{{ticket_id}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Response contains deleted message\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.equal(\"Ticket deleted\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
